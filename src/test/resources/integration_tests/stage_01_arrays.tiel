print("arrays:begin");

fun makePair(a, b) {
    return [a, b];
}

fun makeNested() {
    return [[1, 2], [3, 4], ["x", "y", [10, 20]]];
}

fun id(x) {
    return x;
}

var numbers = [10, 20, 30, 40];
print(numbers[0]);
print(numbers[1]);
print(numbers[2]);
print(numbers[3]);

numbers[1] = 99;
numbers[3] = numbers[0];
print(numbers[0]);
print(numbers[1]);
print(numbers[2]);
print(numbers[3]);

var matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
];

print(matrix[0][0]);
print(matrix[1][1]);
print(matrix[2][2]);

matrix[0][2] = 300;
matrix[2][0] = 700;
print(matrix[0][2]);
print(matrix[2][0]);

var mixed = [
    "start",
    true,
    [1, false, ["deep", 123]],
    "end"
];

print(mixed[0]);
print(mixed[1]);
print(mixed[2][0]);
print(mixed[2][1]);
print(mixed[2][2][0]);
print(mixed[2][2][1]);
print(mixed[3]);

mixed[2][2][1] = 456;
print(mixed[2][2][1]);

var inner = [5, 6];
var outer = [inner, inner];

print(outer[0][0]);
print(outer[1][1]);

outer[0][0] = 55;
print(inner[0]);
print(outer[1][0]);

outer[1][1] = 66;
print(inner[1]);
print(outer[0][1]);

var board = [
    ["a1", "a2"],
    ["b1", "b2"]
];

print(board[0][0]);
print(board[0][1]);
print(board[1][0]);
print(board[1][1]);

board[1] = ["x1", "x2"];
print(board[1][0]);
print(board[1][1]);

board[0][1] = board[1][0];
print(board[0][1]);

var nested = [[[1], [2]], [[3], [4]]];
print(nested[0][0][0]);
print(nested[0][1][0]);
print(nested[1][0][0]);
print(nested[1][1][0]);

nested[1][0][0] = 33;
nested[0][1] = nested[1][0];
print(nested[1][0][0]);
print(nested[0][1][0]);

// functions returning arrays
var pair = makePair(7, 8);
print(pair[0]);
print(pair[1]);

print(makePair(11, 22)[0]);
print(makePair(11, 22)[1]);

var fromFunction = makeNested();
print(fromFunction[0][0]);
print(fromFunction[0][1]);
print(fromFunction[1][0]);
print(fromFunction[1][1]);
print(fromFunction[2][0]);
print(fromFunction[2][1]);
print(fromFunction[2][2][0]);
print(fromFunction[2][2][1]);

// indexing arbitrary expressions
print([100, 200, 300][0]);
print([100, 200, 300][1]);
print([100, 200, 300][2]);

print([[1, 2], [3, 4]][0][1]);
print([[1, 2], [3, 4]][1][0]);

print(id([9, 8, 7])[2]);
print(id([[10], [20], [30]])[1][0]);

print(makePair(makePair(1, 2), makePair(3, 4))[0][1]);
print(makePair(makePair(1, 2), makePair(3, 4))[1][0]);

print(makeNested()[2][2][1]);

var exprTarget = [0, [1, 2], 3];
id(exprTarget)[1][0] = 111;
print(exprTarget[1][0]);

makeNested()[2][2][0]; // evaluated but ignored on purpose

print("arrays:end");